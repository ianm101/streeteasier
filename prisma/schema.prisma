// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth adapter tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Phase 1 models
model User {
  id                 String    @id @default(cuid())
  email              String?   @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  googleRefreshToken String?
  gmailHistoryId     String?
  createdAt          DateTime  @default(now())

  accounts           Account[]
  sessions           Session[]
  apartmentsAdded    Apartment[] @relation("AddedBy")
  pointForApartments Apartment[] @relation("PointPerson")
  rankings           Ranking[]
  notes              Note[]
  brokerThreads      BrokerThread[]
}

model Apartment {
  id            String   @id @default(cuid())
  address       String
  unit          String?
  neighborhood  String?
  borough       String?
  price         Int?
  beds          Float?
  baths         Float?
  sqft          Int?
  floor         Int?
  listingUrl    String?
  source        String
  status        String   @default("interested")

  brokerName    String?
  brokerEmail   String?
  brokerPhone   String?

  floorPlanUrl  String?
  screenshotUrl String?
  photoUrls     String[]

  lat           Float?
  lng           Float?

  descriptionSummary String?
  salientFeatures    String[]
  notes              String?

  // Email thread tracking for updates
  emailThreadId      String?   // Gmail thread ID to detect new messages
  lastEmailAt        DateTime? // Timestamp of last email in thread

  addedById     String
  addedBy       User     @relation("AddedBy", fields: [addedById], references: [id])
  pointPersonId String?
  pointPerson   User?    @relation("PointPerson", fields: [pointPersonId], references: [id])

  amenities       ApartmentAmenity[]
  rankings        Ranking[]
  apartmentNotes  Note[]
  actionItems     ActionItem[]
  timeline        Timeline[]
  documents       Document[]
  fileAttachments FileAttachment[]

  brokerThreadId  String?
  brokerThread    BrokerThread? @relation(fields: [brokerThreadId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ApartmentAmenity {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  key         String
  @@unique([apartmentId, key])
}

model Ranking {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  rank        Int
  updatedAt   DateTime  @updatedAt
  @@unique([apartmentId, userId])
}

model Note {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  body        String
  createdAt   DateTime  @default(now())
}

model ActionItem {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  type        String    // "application_pending", "schedule_tour", "submit_documents", "sign_lease", "follow_up"
  description String
  status      String    @default("pending") // "pending", "completed", "overdue"
  dueDate     DateTime?
  link        String?   // Application URL, document link, etc.
  fileUrl     String?   // Attached file URL

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Timeline {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  event       String    // "inquiry_sent", "tour_scheduled", "tour_completed", "application_submitted", "application_approved", "lease_signed"
  description String
  occurredAt  DateTime  @default(now())

  createdAt   DateTime  @default(now())
}

model Document {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  name        String    // "Photo ID", "Pay Stubs", "Bank Statements", "W2", "Tax Transcript"
  required    Boolean   @default(true)
  status      String    @default("pending") // "pending", "uploaded", "approved", "rejected"
  fileUrl     String?
  notes       String?   // Additional notes about the document

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FileAttachment {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  name        String    // Original filename or description
  type        String    // "application_pdf", "lease_agreement", "email_attachment", "web_application_url", "other"
  url         String    // Storage URL or web application URL
  mimeType    String?   // MIME type for downloaded files
  size        Int?      // File size in bytes
  source      String    @default("manual_upload") // "manual_upload", "gmail_attachment", "web_url"

  // Gmail attachment metadata
  gmailMessageId String? // If from Gmail, the message ID
  gmailAttachmentId String? // Gmail's attachment ID

  notes       String?   // User notes about this file

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BrokerThread {
  id                 String   @id @default(cuid())

  // Broker information
  brokerName         String
  brokerEmail        String
  brokerPhone        String?
  brokerCompany      String?  // "Corcoran", "Compass", etc.

  // Email thread tracking
  emailThreadId      String   @unique  // Gmail thread ID
  subject            String
  lastEmailAt        DateTime
  messageCount       Int      @default(1)

  // AI-extracted information
  summary            String?   // Claude Haiku summary of conversation
  status             String    @default("active")  // "active", "cold", "completed"

  // Mentioned apartments (may not be full listings yet)
  mentionedAddresses String[] // ["225 Eighth Ave #2D", "225 Eighth Ave #4D"]
  mentionedPrices    Int[]    // [null, 8200]

  // User asks/requests extracted by AI
  userAsks           String[] // ["Schedule showing", "Submit documents"]
  brokerAsks         String[] // ["Fill out application", "Send paystubs"]

  // Relations
  apartments         Apartment[] // Apartments created from this thread
  addedById          String
  addedBy            User      @relation(fields: [addedById], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
